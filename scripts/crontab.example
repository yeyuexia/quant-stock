# Paste these lines into `crontab -e`. Times are your local wall clock,
# NOT market time — these assume you are in ET (US/Eastern). Adjust hours
# if your machine is in a different timezone:
#   - If machine is UTC, add 4 (DST) or 5 (standard) → rebalancer at 13:35 / 14:35
#   - If machine is PT, subtract 3 → rebalancer at 06:35
#
# Watchdog — 8:30 AM ET weekdays
30 8 * * 1-5 /Users/zl/works/stock/scripts/cron-wrapper.sh watchdog.py >> /Users/zl/works/stock/.cache/watchdog.log 2>&1

# Rebalancer core — 9:35 AM ET weekdays (cadence-gated, safe to run daily)
35 9 * * 1-5 /Users/zl/works/stock/scripts/cron-wrapper.sh rebalancer.py --tranche core >> /Users/zl/works/stock/.cache/rebalance.log 2>&1

# Rebalancer aggressive — 9:35 AM ET Mondays only (weekly cadence)
35 9 * * 1 /Users/zl/works/stock/scripts/cron-wrapper.sh rebalancer.py --tranche aggressive >> /Users/zl/works/stock/.cache/rebalance.log 2>&1

# Executor — every 10 min, 10:00–15:50 ET weekdays
*/10 10-15 * * 1-5 /Users/zl/works/stock/scripts/cron-wrapper.sh executor.py >> /Users/zl/works/stock/.cache/executor.log 2>&1

# Quant review subagent — 7 PM ET weekdays (= 3h after market close).
# Invokes the `claude` CLI locally against the user's CC subscription;
# writes strategy overrides + Telegram notification to .cache/.
# Runs Mon-Fri in ET; stays on same calendar day since close + 3h is still evening.
0 19 * * 1-5 /Users/zl/works/stock/scripts/cron-wrapper.sh scripts/quant_review_local.py >> /Users/zl/works/stock/.cache/quant.log 2>&1

# Discovery — weekly watchlist refresh, Sundays 8 AM ET (before Mon rebalance).
# Scans the multi-index universe (S&P 500 + Nasdaq-100 + S&P 400) two-stage and
# appends the top names to watchlist_auto.json. config.py seed is never rewritten.
0 8 * * 0 /Users/zl/works/stock/scripts/cron-wrapper.sh discovery.py --update >> /Users/zl/works/stock/.cache/discovery.log 2>&1
